@model WebApplicationForEnterprise.Models.PurchaseOrder
@using WebApplicationForEnterprise.Enums

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>PurchaseOrder</h4>
    <hr />

    <dl class="row">

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.OrderDate)
        </dt>

        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.OrderDate)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Status)
        </dt>

        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Status)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Supplier)
        </dt>

        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Supplier.Name)
        </dd>

    </dl>
</div>

<div>
    <a asp-action="Edit"
           asp-route-id="@Model.Id">
        Edit
    </a>
    |

    <a asp-action="Index">
        Back to List
    </a>
</div>

<h3 class="mt-4">
    Товари в закупівлі
</h3>

<table class="table">

    <thead>
        <tr>
            <th>Товар</th>
            <th>Кількість</th>
            <th>Ціна</th>
            <th></th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model.PurchaseOrderItems)
        {
            <tr>

                <td>@item.Product?.Name</td>
                <td>@item.Quantity</td>
                <td>@item.Price</td>

                <td>

                    @if (Model.Status != PurchaseOrderStatus.Доставлено)
                    {
                        <a asp-controller="PurchaseOrderItems"
                               asp-action="Edit"
                               asp-route-id="@item.Id">
                            Edit
                        </a>

                        @: |

                        <form asp-controller="PurchaseOrderItems"
                              asp-action="QuickDelete"
                              method="post"
                              style="display:inline-block; margin:0;">

                            <input type="hidden"
                                   name="id"
                                   value="@item.Id" />

                            <button type="submit"
                                    class="btn btn-link p-0 align-baseline">
                                Delete
                            </button>

                        </form>
                    }

                </td>

            </tr>
        }

    </tbody>

</table>

@if (Model.Status != PurchaseOrderStatus.Доставлено)
{
    <a asp-controller="PurchaseOrderItems"
           asp-action="Create"
           asp-route-purchaseOrderId="@Model.Id"
           class="btn btn-primary mt-3">

        Додати товар

    </a>

    <form asp-action="ConfirmDelivery"
          method="post"
          class="mt-3">

        <input type="hidden"
               name="id"
               value="@Model.Id" />

        <button type="submit"
                class="btn btn-success">

            Підтвердити доставку

        </button>

    </form>
}