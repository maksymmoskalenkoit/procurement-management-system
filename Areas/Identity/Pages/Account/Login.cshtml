@page
@model LoginModel

@{
    ViewData["Title"] = "Вхід у систему";
}

<h1>Вхід у систему</h1>

<div class="row">

    <div class="col-md-5">

        <section>

            <form id="account" method="post">

                <h4>Увійдіть у My Wholesale</h4>

                <hr />

                <div asp-validation-summary="ModelOnly"
                     class="text-danger">
                </div>

                <div class="mb-3">

                    <label asp-for="Input.Email"
                           class="form-label">
                    </label>

                    <input asp-for="Input.Email"
                           class="form-control"
                           autocomplete="username" />

                    <span asp-validation-for="Input.Email"
                          class="text-danger">
                    </span>

                </div>

                <div class="mb-3">

                    <label asp-for="Input.Password"
                           class="form-label">
                    </label>

                    <input asp-for="Input.Password"
                           class="form-control"
                           autocomplete="current-password" />

                    <span asp-validation-for="Input.Password"
                          class="text-danger">
                    </span>

                </div>

                <div class="mb-3">

                    <label>
                        <input asp-for="Input.RememberMe"
                               class="form-check-input" />

                        Запам'ятати мене
                    </label>

                </div>

                <button id="login-submit"
                        type="submit"
                        class="btn btn-primary w-100">

                    Увійти

                </button>

            </form>

        </section>

    </div>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}