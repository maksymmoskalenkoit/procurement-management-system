@model WebApplicationForEnterprise.ViewModels.UserViewModel

@{
    ViewData["Title"] = "Видалення";
}

<h1>Видалення користувача</h1>

<div class="card p-4">

    <h4>
        Ви дійсно хочете видалити цього користувача?
    </h4>

    <hr />

    <dl class="row">

        <dt class="col-sm-2">
            Email
        </dt>

        <dd class="col-sm-10">
            @Model.Email
        </dd>

        <dt class="col-sm-2">
            Роль
        </dt>

        <dd class="col-sm-10">
            @Model.RoleName
        </dd>

    </dl>

    <form asp-action="Delete">

        <input type="hidden"
               asp-for="Id" />

        <button type="submit"
                class="btn btn-danger">

            Видалити
        </button>

        <a asp-action="Index"
               class="btn create-btn">

            Скасувати
        </a>

    </form>

</div>