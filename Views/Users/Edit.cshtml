@model WebApplicationForEnterprise.ViewModels.EditUserViewModel

<h1>Змінити роль користувача</h1>

<hr />

<form asp-action="Edit">

    <input asp-for="Id" hidden />

    <div class="mb-3">

        <label asp-for="Email"></label>

        <input asp-for="Email"
               class="form-control"
               readonly />

    </div>

    <div class="mb-3">

        <label asp-for="Role"></label>

        <select asp-for="Role"
                class="form-control"
                asp-items="@(new SelectList(ViewBag.Roles))">
        </select>

    </div>

    <button type="submit"
            class="btn btn-primary">

        Зберегти
    </button>

    <a asp-action="Index"
           class="btn create-btn">

        Назад
    </a>

</form>