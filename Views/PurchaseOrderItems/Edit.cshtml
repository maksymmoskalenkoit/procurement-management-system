@model WebApplicationForEnterprise.Models.PurchaseOrderItem

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>PurchaseOrderItem</h4>
<hr />

<div class="row">
    <div class="col-md-4">

        <form asp-action="Edit">

            <div asp-validation-summary="ModelOnly"
                 class="text-danger">
            </div>

            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="PurchaseOrderId" />

            <div class="form-group">
                <label asp-for="ProductId"
                       class="control-label"></label>

                <select asp-for="ProductId"
                        id="ProductId"
                        class="form-control">

                    @foreach (var product in ViewBag.ProductIdData)
                    {
                        @if (product.Id == Model.ProductId)
                        {
                            <option value="@product.Id"
                                    data-price="@product.PurchasePrice"
                                    selected>
                                @product.Name
                            </option>
                        }
                        else
                        {
                            <option value="@product.Id"
                                    data-price="@product.PurchasePrice">
                                @product.Name
                            </option>
                        }
                    }

                </select>

                <span asp-validation-for="ProductId"
                      class="text-danger">
                </span>
            </div>

            <div class="form-group">
                <label asp-for="Quantity"
                       class="control-label"></label>

                <input asp-for="Quantity"
                       id="Quantity"
                       class="form-control"
                       min="1"/>

                <span asp-validation-for="Quantity"
                      class="text-danger">
                </span>
            </div>

            <div class="form-group">
                <label asp-for="Price"
                       class="control-label"></label>

                <input asp-for="Price"
                       id="Price"
                       class="form-control"
                       readonly />

                <span asp-validation-for="Price"
                      class="text-danger">
                </span>
            </div>

            <br />

            <div class="form-group">
                <input type="submit"
                       value="Save"
                       class="btn btn-primary" />
            </div>

        </form>

    </div>
</div>

<div>
    <a asp-controller="PurchaseOrders"
           asp-action="Details"
           asp-route-id="@Model.PurchaseOrderId">
        Back
    </a>
</div>

@section Scripts
{
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>

        const quantityInput =
        document.getElementById("Quantity");

        const productSelect =
        document.getElementById("ProductId");

        const priceInput =
        document.getElementById("Price");

        function calculatePrice()
        {
            let quantity =
            parseFloat(quantityInput.value) || 0;

            let selectedOption =
            productSelect.options[
            productSelect.selectedIndex];

            let purchasePrice =
            parseFloat(
            selectedOption.dataset.price
            ) || 0;

            priceInput.value =
            quantity * purchasePrice;
        }

        quantityInput.addEventListener(
        "input",
        calculatePrice);

        productSelect.addEventListener(
        "change",
        calculatePrice);

        calculatePrice();

    </script>
}